# Optional: public I-ALiRT data does not require secrets.
IMAP_DATA_ACCESS_URL=https://api.imap-mission.com

# Optional: only for protected/unreleased SDC products. Do not commit real keys.
IMAP_API_KEY=
IMAP_ACCESS_TOKEN=

# Optional: where imap-data-access stores downloaded files.
IMAP_DATA_DIR=./data
