# Public I-ALiRT data does not require credentials.
IALIRT_DATA_ACCESS_URL=https://ialirt.imap-mission.com

# Optional API key for protected/unreleased products. Do not commit real keys.
# When set, the package also expects IALIRT_DATA_ACCESS_URL to end with /api-key.
IMAP_API_KEY=

# Optional override for the on-disk cache used by ialirt-data-access.
IALIRT_DATA_DIR=./data

# Service configuration (used by `ialirt-explorer-service`)
IALIRT_POLL_INTERVAL_SECONDS=30
IALIRT_LOOKBACK_MINUTES=60
IALIRT_SERVICE_HOST=0.0.0.0
IALIRT_SERVICE_PORT=8000
